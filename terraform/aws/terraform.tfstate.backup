            "arn": "arn:aws:ssm:us-east-1:718228864789:document/AddUbuntuSSHKey",
            "attachments_source": [],
            "content": "{\"description\":\"Add SSH public key to ubuntu authorized_keys\",\"mainSteps\":[{\"action\":\"aws:runShellScript\",\"inputs\":{\"runCommand\":[\"install -d -m 700 /home/ubuntu/.ssh\",\"echo 'ssh-rsa  wahidsf@Wahids-MacBook-Air.local' \\u003e\\u003e /home/ubuntu/.ssh/authorized_keys\",\"chown -R ubuntu:ubuntu /home/ubuntu/.ssh\",\"chmod 600 /home/ubuntu/.ssh/authorized_keys\"]},\"name\":\"addKey\"}],\"schemaVersion\":\"2.2\"}",
